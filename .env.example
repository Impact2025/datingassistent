# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Neon PostgreSQL connection strings
# Get from: https://neon.tech (your project dashboard)
POSTGRES_URL=postgresql://user:password@host.neon.tech/database?sslmode=require&pgbouncer=true&connect_timeout=15
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require&pgbouncer=true&connect_timeout=15
POSTGRES_PRISMA_URL=postgresql://user:password@host.neon.tech/database?sslmode=require&channel_binding=require&pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgresql://user:password@host.neon.tech/database?sslmode=require&channel_binding=require

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Secret - MUST be changed in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-IN-PRODUCTION

# Cron Job Secret - Used by Vercel Cron to authenticate scheduled jobs
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# =============================================================================
# FIREBASE (Optional - if still using Firebase Auth)
# =============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# =============================================================================
# AI SERVICES (OpenRouter)
# =============================================================================
# Get your API key from: https://openrouter.ai/keys
# Used for: Photo analysis, Chat coaching, Bio generation
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# =============================================================================
# PAYMENT PROVIDER (Stripe)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
NEXT_PUBLIC_BASE_URL=http://localhost:9000

# =============================================================================
# GOOGLE reCAPTCHA
# =============================================================================
# Get from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# =============================================================================
# EMAIL SERVICE (Resend)
# =============================================================================
# Get your API key from: https://resend.com/api-keys
# Resend Pro provides better deliverability and analytics
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@datingassistent.nl
# Note: With Resend, templates are rendered using React Email (no template IDs needed)

# =============================================================================
# CONTACT FORM (Web3Forms)
# =============================================================================
# Get from: https://web3forms.com/
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# =============================================================================
# SEO INDEXERING (automatisch aanmelden bij zoekmachines bij publicatie)
# =============================================================================
# IndexNow — gratis, ondersteund door Bing, Yandex en Google
# Genereer een willekeurige key, bijv: openssl rand -hex 16
INDEXNOW_KEY=

# Google Search Console Indexing API — vereist een Service Account
# Stap 1: Maak een project aan in https://console.cloud.google.com
# Stap 2: Activeer "Web Search Indexing API"
# Stap 3: Maak een Service Account aan en download het JSON-sleutelbestand
# Stap 4: Voeg het e-mailadres van het Service Account toe als eigenaar in
#          Google Search Console (https://search.google.com/search-console)
# Stap 5: Plak de volledige JSON-inhoud als één regel (of gebruik jq -c):
#          GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'
GOOGLE_SERVICE_ACCOUNT_JSON=

# Publieke URL van de website (zonder trailing slash)
# Wordt gebruikt voor het opbouwen van volledige blog-URLs bij indexering
NEXT_PUBLIC_SITE_URL=https://www.datingassistent.nl

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# Set CORS allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=https://yourdomain.com

# Node Environment
NODE_ENV=development
